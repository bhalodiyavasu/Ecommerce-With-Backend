# Backend API Base URL
# Where to get: The URL of the running backend server. For local development, this is typically http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api

# Default Admin Credentials
# Where to get: The email of the admin account registered or seeded in your database
VITE_ADMIN_EMAIL=admin@gmail.com
# Where to get: The password of the admin account registered or seeded in your database
VITE_ADMIN_PASSWORD=admin1234
